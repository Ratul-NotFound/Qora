# ============================================================
# QORA Research AI — Configuration
# Copy this file to .env and fill in your API keys
# ============================================================

# ---- LLM Provider (OpenAI-compatible) ----------------------
# Works with: OpenAI, Groq, Together AI, Mistral, OpenRouter,
#             Anthropic (via proxy), Ollama (local), etc.
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ---- Optional: Use a different model for heavy tasks -------
LLM_HEAVY_MODEL=gpt-4o

# ---- Semantic Scholar (optional — free, higher rate limits) -
SEMANTIC_SCHOLAR_API_KEY=

# ---- NCBI/PubMed (optional — free, higher rate limits) -----
NCBI_API_KEY=

# ---- CORE (optional — free, higher rate limits) ------------
CORE_API_KEY=

# ---- App Settings ------------------------------------------
MAX_PAPERS_PER_SOURCE=25
MAX_CONCURRENT_SUMMARIES=5
DB_PATH=./qora.db
